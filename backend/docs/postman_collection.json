                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
                                    "var j = {}; try { j = pm.response.json(); } catch (e) {}",
                                    "var token = j && j.data ? j.data.access_token : '';",
                                    "if (token) { pm.collectionVariables.set('access_token', token); }",
                                    "pm.test('access_token exists', function () { pm.expect(token).to.be.a('string').and.not.empty; });"
                                ]
                            }
                        }
